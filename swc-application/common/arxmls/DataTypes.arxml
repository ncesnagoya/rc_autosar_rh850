					<BASE-TYPE-ENCODING>NONE</BASE-TYPE-ENCODING>
					<MEM-ALIGNMENT>0</MEM-ALIGNMENT>
					<NATIVE-DECLARATION>unsigned long</NATIVE-DECLARATION>
				</SW-BASE-TYPE>
			</ELEMENTS>
		</AR-PACKAGE>
