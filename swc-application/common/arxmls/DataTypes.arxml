					<NATIVE-DECLARATION>signed char</NATIVE-DECLARATION>
				</SW-BASE-TYPE>
				<SW-BASE-TYPE>
					<SHORT-NAME>uint16</SHORT-NAME>
					<CATEGORY>FIXED_LENGTH</CATEGORY>
