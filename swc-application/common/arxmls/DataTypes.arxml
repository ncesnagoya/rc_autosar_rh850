					<NATIVE-DECLARATION>unsigned char</NATIVE-DECLARATION>
				</SW-BASE-TYPE>
				<SW-BASE-TYPE>
					<SHORT-NAME>sint8</SHORT-NAME>
					<CATEGORY>FIXED_LENGTH</CATEGORY>
